# Option A — keys next to this example (recommended for “example folder” workflow):
#   cp env.example .env
#   edit .env and set GEMINI_API_KEY (run_agent.py loads backend/.env first, then this .env
#   for any variables that are still unset).
#
# Option B — keys in backend/.env (same as the FastAPI app):
#   paste these lines into agents_market/backend/.env
#
# Do not commit real .env files.

GEMINI_API_KEY=your_gemini_or_google_ai_studio_key
# GOOGLE_API_KEY=your_key_here

# Optional ChatGoogleGenerativeAI.base_url (custom / regional Generative Language host)
# GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com

LLM_BUYER_MODEL=gemini-2.0-flash

# Optional OpenAI for this script only (explicit opt-in)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=

SERVER_URL=http://localhost:4021
BUYER_ID=

# Optional: restrict discover/list/invoke to agents whose name contains this substring (case-insensitive).
# Example for SkyRoute Flight Planning Agent: MARKETPLACE_AGENT_NAME_SUBSTRING=SkyRoute
# MARKETPLACE_AGENT_NAME_SUBSTRING=

# Optional: preset ``walletAddress`` on new buyers (must be Circle-derivable for this entity).
# Precedence: AUTONOMOUS_BUYER_WALLET_ADDRESS, then BUYER_WALLET_ADDRESS. Leave unset to auto-provision
# a buyer wallet pair (recommended). If a buyer with that address already exists, it is reused.
# AUTONOMOUS_BUYER_WALLET_ADDRESS=
# BUYER_WALLET_ADDRESS=

# Example chat server (chat_server.py) port
# AUTONOMOUS_BUYER_CHAT_PORT=9095

# Max seconds for one chat turn (LLM + tools); server returns 504 after this (default 180, max 900)
# AUTONOMOUS_BUYER_REQUEST_TIMEOUT_SEC=180
