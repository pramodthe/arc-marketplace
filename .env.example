# Import BuyerMarketplaceSDK: from test/buyer_agent run:
#   export PYTHONPATH="${PWD}/../../backend/src"
# Or install backend editable from backend/ (see README.md).
RUN_MODE=chat
BUYER_PROMPT=Add 18 and 24
BUYER_BUDGET_USDC=1.0
SERVICE_PRICE_USDC=0.01
REQUEST_TIMEOUT_SECONDS=20
AGENT_CARD_URLS=http://localhost:5051/.well-known/agent-card.json
BUYER_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your_openai_api_key
MAX_TURNS_PER_MESSAGE=8
PAYMENT_MODE=simulate
X402_CHAIN=arcTestnet
X402_PRIVATE_KEY=
TRAVEL_QA_UI_HOST=127.0.0.1
TRAVEL_QA_UI_PORT=7070
TRAVEL_PROVIDER_HOST=127.0.0.1
TRAVEL_DEMO_TIMEOUT_SECONDS=20
TRAVEL_BUDGET_USDC=0.08
