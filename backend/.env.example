PRIVATE_KEY=0x_your_buyer_private_key
# Shared hackathon Gateway treasury key for demo deposits/balance checks.
# x402 paid invokes still route to each seller's registered owner wallet address.
SELLER_PRIVATE_KEY=0x_your_shared_demo_gateway_treasury_private_key
DATABASE_URL=sqlite:///./agents_market.db
PUBLIC_BASE_URL=http://localhost:4021
# Optional comma-separated external A2A-style agent card URLs
EXTERNAL_AGENT_CARDS=

PORT=4021
SERVER_URL=http://localhost:4021
DEPOSIT_AMOUNT=1
BUYER_PROMPT=Give me a short market insight for today.
BUYER_LOOP_SECONDS=0
# summarize | analyze | plan | response | auto
BUYER_TASK=auto
BUYER_BUDGET_USDC=1.0
# Optional platform buyer id from POST /buyers
BUYER_ID=

# Circle + Arc settings required for provider listing, wallet provisioning, and ERC-8004 lifecycle endpoints.
CIRCLE_API_KEY=your_circle_api_key
CIRCLE_ENTITY_SECRET=your_circle_entity_secret
ARC_RPC_URL=https://rpc.testnet.arc.network

# External buyer funding through Arc App Kit / Bridge Kit.
# Use mock for local demos/tests; unset or use real to execute Bridge Kit with env-held keys.
ARC_BRIDGE_WORKER_MODE=mock
ARC_BRIDGE_EVM_PRIVATE_KEY=0x_your_bridge_source_wallet_private_key
ARC_BRIDGE_WORKER_TIMEOUT_SECONDS=600
NODE_BINARY=node

# Optional: metadata URI used by `uv run arc-demo-marketplace`
DEMO_AGENT_METADATA_URI=https://your-agent-domain/.well-known/agent-card.json
